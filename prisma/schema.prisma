// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String   @id
  initialBalance     Float
  dailyLossPercent   Float
  totalLossPercent   Float
  timezone           String

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  riskSnapshots      RiskSnapshot[]
  apiKeys            ApiKey[]
  tradeCommands     TradeCommand[]
  closureLogs       ClosureLog[]
}

model RiskSnapshot {
  id           String   @id @default(cuid())
  accountId    String
  status       String
  balance      Float
  equity       Float
  timestamp    DateTime
  createdAt    DateTime @default(now())

  account      Account  @relation(fields: [accountId], references: [id])
}

model ApiKey {
  id           String   @id @default(cuid())
  accountId    String
  prefix       String   @unique
  hashedSecret String
  name         String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())

  account      Account  @relation(fields: [accountId], references: [id])

  @@index([accountId, revokedAt])
}

model TradeCommand {
  id            String   @id @default(cuid())
  accountId     String
  command       String   // CLOSE_ALL, DISABLE_TRADING, ALERT_ONLY
  reason        String   // LOCKED_DAILY, CRITICAL_95, etc.
  executed      Boolean  @default(false)
  executedAt    DateTime?
  createdAt     DateTime @default(now())

  account       Account  @relation(fields: [accountId], references: [id])
  closureLog    ClosureLog?

  @@index([accountId, executed, createdAt])
}

model ClosureLog {
  id                String   @id @default(cuid())
  commandId         String?  @unique
  accountId         String
  reason            String
  closedPositions   Int
  totalPnL          Float
  createdAt         DateTime @default(now())

  command           TradeCommand? @relation(fields: [commandId], references: [id])
  account           Account  @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}
