# ============================================
# YouTube Multi-Channel Management Platform
# ============================================

# Application
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-2024
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database (Docker)
DATABASE_URL=postgresql://ytmanager:ytmanager_password@localhost:5432/youtube_manager?schema=public

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key

# Encryption key for OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=32-char-encryption-key-change-me!
